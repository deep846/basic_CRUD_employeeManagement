{
	"name": "empmanagement",
	"version": "1.0.0",
	"description": "A simple CAP project.",
	"dependencies": {
		"@cap-js/hana": "^2",
		"@sap/cds": "^9",
		"@sap/xssec": "^4",
		"express": "^4",
		"@sap-cloud-sdk/connectivity": "^4",
		"@sap-cloud-sdk/http-client": "^4",
		"@sap-cloud-sdk/resilience": "^4"
	},
	"devDependencies": {
		"@cap-js/sqlite": "^2",
		"@sap/cds-dk": "^9",
		"cds-plugin-ui5": "^0.13.0",
		"mbt": "^1.2.29",
		"rimraf": "^5.0.5",
		"@sap/dev-cap-tools": "^1.31.0"
	},
	"scripts": {
		"start": "cds-serve",
		"watch-employeemanagement": "cds watch --open employeemanagement/index.html?sap-ui-xx-viewCache=false --livereload false",
		"undeploy": "cf undeploy empmanagement --delete-services --delete-service-keys --delete-service-brokers",
		"build": "rimraf resources mta_archives && mbt build --mtar archive",
		"deploy": "cf deploy mta_archives/archive.mtar --retries 1"
	},
	"private": true,
	"workspaces": [
		"app/*"
	],
	"cds": {
		"requires": {
			"server": {
				"index": true
			},
			"[development]": {
				"auth": {
					"kind": "mocked",
					"users": {
						"deep@gmail.com": {
							"password": "12345",
							"roles": [
								"manager"
							]
						},
						"deep@sap.com": {
							"password": "12345",
							"roles": [
								"user"
							]
						}
					}
				}
			},
			"[production]": {
				"db": "hana",
				"auth": "xsuaa"
			},
			"[hybrid]": {
				"db": "hana"
			},
			"student": {
				"kind": "odata",
				"model": "srv/external/student",
				"credentials": {
					"url": "http://localhost:4004/odata/v4/student"
				}
			}
		}
	}
}